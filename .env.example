# SSD environment variables
# Copy to .env and fill in your paths: cp .env.example .env && source .env
# Required for running inference and benchmarks.

# HuggingFace hub directory (contains models--org--name/ subdirs).
# Example: /data/huggingface/hub — NOT the parent of that directory.
export SSD_HF_CACHE=/path/to/huggingface/hub

# Processed benchmark datasets (humaneval/, alpaca/, c4/, gsm8k/, ultrafeedback/).
# Generate with: python scripts/get_data_from_hf.py --num-samples 10000
export SSD_DATASET_DIR=/path/to/processed_datasets

# CUDA architecture for kernel compilation (Linux + NVIDIA only).
# 9.0 = H100/H200, 8.0 = A100, 8.9 = L40/4090
export SSD_CUDA_ARCH=9.0

